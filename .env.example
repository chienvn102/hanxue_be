# Environment
NODE_ENV=production
PORT=3636

# Database
DB_HOST=your-database-host
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=hanxue_db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google Sign-In
GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com

# Gmail password reset email
GMAIL_USER=your-gmail-address@gmail.com
GMAIL_CLIENT_ID=your-google-oauth-client-id
GMAIL_CLIENT_SECRET=your-google-oauth-client-secret
GMAIL_REFRESH_TOKEN=your-google-oauth-refresh-token
# Optional dev fallback if OAuth2 is not ready:
GMAIL_APP_PASSWORD=
MAIL_FROM=HanXue <your-gmail-address@gmail.com>

# SMTP transport (defaults target Gmail over IPv4-friendly port 587)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true

# CORS (update with your Vercel domain)
CORS_ORIGIN=https://hanxue.vercel.app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Groq AI (for AI chat feature)
GROQ_API_KEY=
