# Environment
NODE_ENV=production
PORT=3636

# Database
DB_HOST=your-database-host
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=hanxue_db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google Sign-In
GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com

# Email provider. Use Resend in production to avoid SMTP blocks on Droplets.
EMAIL_PROVIDER=resend
RESEND_API_KEY=
RESEND_FROM=HanXue <noreply@hanxue.io.vn>
RESEND_API_URL=https://api.resend.com/emails
# Optional: send a real test email when running npm run verify:email
RESEND_VERIFY_SEND_TO=

# Gmail/SMTP fallback for local or non-blocked servers
GMAIL_USER=your-gmail-address@gmail.com
GMAIL_CLIENT_ID=your-google-oauth-client-id
GMAIL_CLIENT_SECRET=your-google-oauth-client-secret
GMAIL_REFRESH_TOKEN=your-google-oauth-refresh-token
# Optional dev fallback if OAuth2 is not ready:
GMAIL_APP_PASSWORD=
MAIL_FROM=HanXue <your-gmail-address@gmail.com>

# SMTP transport (defaults target Gmail over IPv4-friendly port 587)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true

# CORS (update with your Vercel domain)
CORS_ORIGIN=https://hanxue.vercel.app
APP_URL=https://hanxue.vercel.app

# Public API base used by Swagger/OpenAPI docs
API_PUBLIC_URL=https://api.example.com/hanxue
SWAGGER_SERVER_URLS=https://api.example.com/hanxue

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Google Cloud AI / Speech / Storage
GOOGLE_APPLICATION_CREDENTIALS=/etc/hanxue/gcp-sa.json
GCP_PROJECT_ID=hanxue-prod
GOOGLE_CLOUD_PROJECT=hanxue-prod
GCP_LOCATION=asia-southeast1
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=60000
HSK_AI_GRADING_ENABLED=true
HSK_AI_WRITING_PASS_SCORE=70

# Lesson gating + quiz + Groq writing grading (migration 031)
#   COURSE_UNLOCK_ENFORCEMENT → khóa khóa-trước & bài-trước. BẬT mặc định (admin bypass);
#                               đặt =false để tắt hoàn toàn gating.
#   WRITING_AI_GRADING_ENABLED=true → chấm bài viết của bài tập bằng Groq (cần GROQ_API_KEY,
#                                     nếu thiếu/lỗi tự fallback chấm theo keyword)
#   LESSON_QUIZ_SIZE   → số câu quiz tối đa mỗi bài (mặc định 10)
#   LESSON_PASS_PCT    → ngưỡng đạt của 1 bài học = avg(quiz, viết) (mặc định 70)
COURSE_UNLOCK_ENFORCEMENT=true
WRITING_AI_GRADING_ENABLED=false
LESSON_QUIZ_SIZE=10
LESSON_PASS_PCT=70

# HSK OCR import hook (admin-only, creates draft inactive exams)
HSK_IMPORT_MODEL=gemini-3.5-flash
HSK_IMPORT_LOCATION=global
HSK_IMPORT_TIMEOUT_MS=180000
HSK_IMPORT_MAX_RAW_TEXT_CHARS=180000
HSK_IMPORT_MAX_OUTPUT_TOKENS=32768
HSK_IMPORT_THINKING_BUDGET=
HSK_IMPORT_CHUNKED=true
HSK_IMPORT_OCR_ENABLED=false
HSK_IMPORT_FORCE_DOCUMENT_AI=false
# Enable Document AI fallback only when configured.
DOCUMENT_AI_PROCESSOR_NAME=projects/<project>/locations/<location>/processors/<processor>
HSK_IMPORT_PDF_MAX_MB=25
HSK_IMPORT_AUDIO_MAX_MB=50
HSK_IMPORT_ANSWER_MAX_MB=10

GCS_BUCKET_AUDIO=hanxue-audio
GCS_BUCKET_IMAGES=hanxue-images
GCS_BUCKET_MEDIA=
GCS_PUBLIC_BASE_URL=https://storage.googleapis.com
GCS_UPLOAD_PUBLIC=false
# Signed URL TTL khi serve audio từ bucket private (mặc định 24h)
GCS_SIGNED_URL_TTL_MS=86400000
GCP_SPEECH_LANGUAGE=cmn-Hans-CN
GCP_SPEECH_SAMPLE_RATE=16000
GCP_SPEECH_TIMEOUT_MS=20000
GCP_TTS_AUDIO_ENCODING=MP3
GCP_TTS_VOICE_FEMALE=cmn-CN-Wavenet-A
GCP_TTS_VOICE_MALE=cmn-CN-Wavenet-B
GCP_TTS_VOICE_FEMALE2=cmn-CN-Wavenet-C
GCP_TTS_VOICE_MALE2=cmn-CN-Wavenet-D
GCP_TTS_TIMEOUT_MS=20000

# Web Push notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@hanxue.io.vn

# Deprecated legacy providers. Keep empty in production after GCP migration.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TRANSLATE_ENABLED=true
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_SPEECH_LANGUAGE=zh-CN
AZURE_SPEECH_VOICE=zh-CN-XiaoxiaoNeural
AZURE_SPEECH_TIMEOUT_MS=15000

# OpenAI realtime pronunciation/chat bridge
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=alloy
OPENAI_REALTIME_TTL_SECONDS=600
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Optional import/extraction integrations
PDF_EXTRACT_URL=
PDF_EXTRACT_TIMEOUT_MS=120000
FORVO_API_KEY=

# Runtime/tooling
PUBLIC_AUDIO_DIR=
PYTHON_BIN=python3
FFMPEG_BIN=ffmpeg
EDGE_TTS_VOICE_FEMALE=zh-CN-XiaoxiaoNeural
EDGE_TTS_VOICE_MALE=zh-CN-YunxiNeural
EDGE_TTS_TIMEOUT_MS=30000
SCHEDULER_TIMEZONE=Asia/Ho_Chi_Minh
DAILY_XP_GOAL=50
SYLLABLE_TTS_MAX_CONCURRENT=2
